# 二选一：
# 1) 本地 SQLite（默认：仓库内 herb_review_system/data/herb_review.db）
# SQLITE_PATH=E:/Other/Work/ChatGLM3/ChatGLM3-main/herb_review_system/data/herb_review.db

# 2) 上线 PostgreSQL（整库 URL，优先级高于 SQLITE_PATH）
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/herb_review

# API
API_V1_PREFIX=/api/v1
API_ROOT_PATH=
CORS_ORIGINS=*

# JWT（上线务必更换）
JWT_SECRET=please-change-this-secret-in-production
JWT_EXPIRE_MINUTES=10080

# 开发：允许 X-Dev-Pharmacist-Id 头绕过 JWT（仅本地，上线设为 0）
DEV_ALLOW_HEADER_AUTH=1
